{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Swarm Seeds 04 answer block",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "block_id", "results"],
  "properties": {
    "schema_version": {"type": "string", "const": "4.0"},
    "block_id": {"type": "string", "minLength": 1, "maxLength": 80},
    "results": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["case_id", "answer", "confidence", "rule_summary", "check_summary"],
        "properties": {
          "case_id": {"type": "string", "minLength": 1, "maxLength": 80},
          "answer": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": {"type": "string", "pattern": "^(0|-?[1-9][0-9]*)$"}
          },
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "rule_summary": {"type": "string", "maxLength": 180},
          "check_summary": {"type": "string", "maxLength": 140}
        }
      }
    }
  }
}
